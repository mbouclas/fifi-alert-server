{% extends "common/layout.nunj" %}

{% block title %}Your Password Has Been Changed{% endblock %}

{% block header %}Password Successfully Changed{% endblock %}

{% block content %}
  <mj-text font-size="20px" font-weight="bold" color="#333333" padding-bottom="20px">
    Hello {{ user.firstName|default('there') }}!
  </mj-text>
  
  <mj-text padding-bottom="20px">
    This is a confirmation that your FiFi Alert account password was successfully changed.
  </mj-text>

  <mj-text padding-bottom="5px">
    <strong>Change Date & Time:</strong> {{ timestampFormatted }}
  </mj-text>

  <mj-text padding-bottom="20px">
    <strong>Account Email:</strong> {{ user.email }}
  </mj-text>

  <mj-divider border-color="#E0E0E0" border-width="1px" padding="20px 0px"></mj-divider>

  <mj-text padding-bottom="15px" font-size="16px" color="#28a745" font-weight="bold">
    ✅ Your account is secure
  </mj-text>

  <mj-text padding-bottom="20px">
    You can now log in to your FiFi Alert account using your new password. All existing sessions on other devices have been invalidated for security.
  </mj-text>

  <mj-button background-color="#007bff" color="#ffffff" href="{{ appUrl }}/auth/login" padding="15px 0px">
    Log In to FiFi Alert
  </mj-button>

  <mj-divider border-color="#E0E0E0" border-width="1px" padding="20px 0px"></mj-divider>

  <mj-text padding-bottom="20px" font-size="16px" color="#d9534f" font-weight="bold">
    ⚠️ Didn't change your password?
  </mj-text>

  <mj-text padding-bottom="15px">
    If you didn't make this change, someone may have unauthorized access to your account. Please take immediate action:
  </mj-text>

  <mj-button background-color="#d9534f" color="#ffffff" href="{{ appUrl }}/auth/forgot-password" padding="15px 0px">
    Reset Password Immediately
  </mj-button>

  <mj-text padding-top="20px" padding-bottom="10px" font-size="14px">
    <strong>If you suspect unauthorized access:</strong>
  </mj-text>

  <mj-text padding-bottom="5px">
    1. Reset your password using the button above
  </mj-text>
  
  <mj-text padding-bottom="5px">
    2. Check your email for any unauthorized password reset requests
  </mj-text>
  
  <mj-text padding-bottom="5px">
    3. Review your recent account activity
  </mj-text>
  
  <mj-text padding-bottom="20px">
    4. Contact our support team immediately for assistance
  </mj-text>

  <mj-divider border-color="#E0E0E0" border-width="1px" padding="20px 0px"></mj-divider>

  <mj-text padding-bottom="10px" font-size="14px" color="#666666">
    <strong>Security Best Practices:</strong>
  </mj-text>

  <mj-text padding-bottom="5px" font-size="14px" color="#666666">
    • Use a strong, unique password for FiFi Alert
  </mj-text>

  <mj-text padding-bottom="5px" font-size="14px" color="#666666">
    • Never share your password with anyone
  </mj-text>

  <mj-text padding-bottom="5px" font-size="14px" color="#666666">
    • Change your password regularly
  </mj-text>

  <mj-text padding-bottom="20px" font-size="14px" color="#666666">
    • Be cautious of phishing emails asking for your credentials
  </mj-text>
{% endblock %}

{% block footer %}
  <mj-text align="center" font-size="12px" color="#999999" padding="10px 0px">
    Need help? Visit our <a href="{{ appUrl }}/support" style="color: #007bff;">Support Center</a>
  </mj-text>
  
  <mj-text align="center" font-size="12px" color="#999999" padding="5px 0px">
    FiFi Alert - Protecting your account and your pets
  </mj-text>
{% endblock %}
