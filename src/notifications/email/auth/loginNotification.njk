{% extends "common/layout.nunj" %}

{% block title %}New Login to Your Account{% endblock %}

{% block header %}Security Alert: New Login Detected{% endblock %}

{% block content %}
  <mj-text font-size="20px" font-weight="bold" color="#333333" padding-bottom="20px">
    Hello {{ user.firstName|default('there') }}!
  </mj-text>
  
  <mj-text padding-bottom="20px">
    We detected a new login to your FiFi Alert account. If this was you, you can safely ignore this email.
  </mj-text>

  <mj-divider border-color="#E0E0E0" border-width="1px" padding="20px 0px"></mj-divider>

  <mj-text padding-bottom="10px" font-size="16px" font-weight="bold">
    Login Details:
  </mj-text>

  <mj-text padding-bottom="5px">
    <strong>Time:</strong> {{ loginDetails.timestampFormatted }}
  </mj-text>

  {% if loginDetails.ipAddress %}
  <mj-text padding-bottom="5px">
    <strong>IP Address:</strong> {{ loginDetails.ipAddress }}
  </mj-text>
  {% endif %}

  {% if loginDetails.location %}
  <mj-text padding-bottom="5px">
    <strong>Location:</strong> {{ loginDetails.location }}
  </mj-text>
  {% endif %}

  {% if loginDetails.userAgent %}
  <mj-text padding-bottom="20px">
    <strong>Device:</strong> {{ loginDetails.userAgent }}
  </mj-text>
  {% endif %}

  <mj-divider border-color="#E0E0E0" border-width="1px" padding="20px 0px"></mj-divider>

  <mj-text padding-bottom="20px" font-size="16px" color="#d9534f" font-weight="bold">
    ⚠️ Wasn't you? Take action immediately:
  </mj-text>

  <mj-text padding-bottom="15px">
    If you don't recognize this login, someone may have accessed your account without permission. Please secure your account right away:
  </mj-text>

  <mj-button background-color="#d9534f" color="#ffffff" href="{{ appUrl }}/auth/change-password" padding="15px 0px">
    Change Password Now
  </mj-button>

  <mj-text padding-top="20px" padding-bottom="10px" font-size="14px">
    <strong>Additional security steps:</strong>
  </mj-text>

  <mj-text padding-bottom="5px">
    1. Change your password immediately
  </mj-text>
  
  <mj-text padding-bottom="5px">
    2. Review your recent account activity
  </mj-text>
  
  <mj-text padding-bottom="5px">
    3. Check for any unauthorized alerts or sightings
  </mj-text>
  
  <mj-text padding-bottom="20px">
    4. Contact support if you need assistance
  </mj-text>

  <mj-divider border-color="#E0E0E0" border-width="1px" padding="20px 0px"></mj-divider>

  <mj-text padding-bottom="10px" font-size="14px" color="#666666">
    <strong>Security Tip:</strong> Always use a strong, unique password for your account and never share it with anyone.
  </mj-text>
{% endblock %}

{% block footer %}
  <mj-text align="center" font-size="12px" color="#999999" padding="10px 0px">
    Security concerns? Contact us immediately: <a href="{{ appUrl }}/support" style="color: #007bff;">Support Center</a>
  </mj-text>
  
  <mj-text align="center" font-size="12px" color="#999999" padding="5px 0px">
    FiFi Alert - Your security is our priority
  </mj-text>
{% endblock %}
