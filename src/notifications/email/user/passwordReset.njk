{% extends "common/layout.nunj" %}

{% block title %}Reset Your Password - FiFi Alert{% endblock %}

{% block header %}Password Reset Request 🔒{% endblock %}

{% block content %}
  <mj-text font-size="18px" font-weight="bold" color="#333333" padding-bottom="20px">
    Hello {{ user.firstName|default('there') }},
  </mj-text>
  
  <mj-text padding-bottom="20px">
    We received a request to reset the password for your FiFi Alert account. If you made this request, click the button below to create a new password.
  </mj-text>
  
  <mj-button background-color="#007bff" color="#ffffff" href="{{ resetLink }}" padding="15px 0px">
    Reset Password
  </mj-button>
  
  <mj-text padding-top="20px" font-size="12px" color="#666666">
    If the button doesn't work, copy and paste this URL into your browser:<br/>
    <a href="{{ resetLink }}" style="color: #007bff;">{{ resetLink }}</a>
  </mj-text>
  
  <mj-divider border-width="1px" border-color="#e0e0e0" padding="30px 0px" />
  
  <mj-text font-size="13px" color="#666666" padding-bottom="10px">
    <strong>This link will expire in {{ expiresIn|default('1 hour') }}.</strong>
  </mj-text>
  
  <mj-text font-size="13px" color="#666666" padding-bottom="10px">
    If you didn't request a password reset, you can safely ignore this email. Your password will not be changed.
  </mj-text>
  
  <mj-text font-size="13px" color="#666666">
    For security reasons, we recommend:
  </mj-text>
  
  <mj-text font-size="13px" color="#666666" padding-left="20px">
    • Using a strong, unique password<br/>
    • Not sharing your password with anyone<br/>
    • Enabling two-factor authentication (coming soon!)
  </mj-text>
  
  <mj-text padding-top="20px" font-size="12px" color="#999999">
    If you're having trouble or didn't request this reset, please contact our support team immediately.
  </mj-text>
{% endblock %}
