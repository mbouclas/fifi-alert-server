{% extends "common/layout.nunj" %}

{% block title %}Forgot Your Password? - FiFi Alert{% endblock %}

{% block header %}Forgot Your Password? 🔑{% endblock %}

{% block content %}
  <mj-text font-size="18px" font-weight="bold" color="#333333" padding-bottom="20px">
    Hi {{ user.firstName|default('there') }},
  </mj-text>
  
  <mj-text padding-bottom="20px">
    No worries! It happens to the best of us. Click the button below to reset your FiFi Alert password.
  </mj-text>
  
  <mj-button background-color="#007bff" color="#ffffff" href="{{ resetLink }}" padding="15px 0px">
    Reset My Password
  </mj-button>
  
  <mj-text padding-top="20px" font-size="12px" color="#666666">
    If the button doesn't work, copy and paste this URL into your browser:<br/>
    <a href="{{ resetLink }}" style="color: #007bff;">{{ resetLink }}</a>
  </mj-text>
  
  <mj-divider border-width="1px" border-color="#e0e0e0" padding="30px 0px" />
  
  <mj-text font-size="13px" color="#666666" padding-bottom="10px">
    <strong>🕐 This link expires in {{ expiresIn|default('1 hour') }}</strong>
  </mj-text>
  
  <mj-text font-size="13px" color="#666666" padding-bottom="20px">
    Didn't request this? You can safely ignore this email. Your account remains secure.
  </mj-text>
  
  <mj-text font-size="12px" color="#999999">
    Need help? Contact us at support@fifi-alert.com
  </mj-text>
{% endblock %}
