{% extends "common/layout.nunj" %}

{% block title %}Verify Your Email Address{% endblock %}

{% block header %}Verify Your Email Address{% endblock %}

{% block content %}
  <mj-text font-size="20px" font-weight="bold" color="#333333" padding-bottom="20px">
    Hello {{ user.firstName|default('there') }}!
  </mj-text>

  <mj-text padding-bottom="20px">
    Thanks for creating your FiFi Alert account. Please verify your email address before logging in.
  </mj-text>

  <mj-text padding-bottom="20px">
    Click the button below to verify your account:
  </mj-text>

  <mj-button background-color="#2563eb" color="#ffffff" href="{{ verificationUrl }}" padding="15px 0px">
    Verify Email Address
  </mj-button>

  <mj-text padding-top="20px" font-size="12px" color="#666666">
    If the button does not work, copy and paste this URL into your browser:<br/>
    <a href="{{ verificationUrl }}" style="color: #2563eb;">{{ verificationUrl }}</a>
  </mj-text>

  <mj-divider border-color="#E0E0E0" border-width="1px" padding="20px 0px"></mj-divider>

  <mj-text padding-bottom="10px" font-size="14px" color="#666666">
    This verification link expires in {{ expirationHours }} hours.
  </mj-text>

  <mj-text padding-bottom="10px" font-size="14px" color="#666666">
    If you did not create a FiFi Alert account, you can safely ignore this email.
  </mj-text>
{% endblock %}

{% block footer %}
  <mj-text align="center" font-size="12px" color="#999999" padding="10px 0px">
    FiFi Alert - Helping reunite families with their lost pets
  </mj-text>
{% endblock %}
