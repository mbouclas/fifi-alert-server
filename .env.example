# =============================================================================
# FIFI ALERT - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# PostgreSQL connection string with PostGIS extension enabled
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For local development: postgresql://postgres:postgres@localhost:5432/fifi_alert_dev
DATABASE_URL="postgresql://user:password@localhost:5432/fifi_alert_dev"

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------------------------------------------
# Redis is used for:
# - BullMQ job queue (notification processing)
# - Rate limiting (alert creation limits)
# - Alert zones caching (high-performance notification matching)
# - Session storage (future)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty for local development without auth
REDIS_DB=0  # Redis database number (0-15)
REDIS_URL=redis://localhost:6379  # Alternative: full Redis connection URL

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# Server port
PORT=3000

# Environment: development | staging | production
# Affects logging level and error detail in responses
NODE_ENV=development

# Base URL for generating file upload URLs
# Development: http://localhost:3000
# Production: https://api.yourapp.com
API_BASE_URL=http://localhost:3000

# Log level: error | warn | info | debug
# Production should use 'info' or 'warn'
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# AUTHENTICATION & AUTHORIZATION
# -----------------------------------------------------------------------------
# Password validation
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_MAX_LENGTH=128

# JWT Token Configuration
# SECURITY: Generate strong random secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# Minimum 32 characters recommended
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars-CHANGE-THIS
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars-CHANGE-THIS

# Token expiration times
# Access token: short-lived (15 minutes recommended)
# Refresh token: long-lived (7 days recommended)
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# Development: http://localhost:3000,http://localhost:3001
# Production: https://app.yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# PUSH NOTIFICATIONS - FIREBASE CLOUD MESSAGING (Android)
# -----------------------------------------------------------------------------
# Get credentials from Firebase Console:
# 1. Go to Project Settings > Service Accounts
# 2. Click "Generate New Private Key"
# 3. Download JSON file
# 4. Extract these values from the JSON:
#    - FCM_PROJECT_ID from "project_id"
#    - FCM_CLIENT_EMAIL from "client_email"
#    - FCM_PRIVATE_KEY from "private_key" (keep newlines as \n)

FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# Optional: Leave empty to disable FCM (notifications will be logged but not sent)
# Useful for local development without Firebase setup

# -----------------------------------------------------------------------------
# PUSH NOTIFICATIONS - APPLE PUSH NOTIFICATIONS (iOS)
# -----------------------------------------------------------------------------
# Get credentials from Apple Developer Console:
# 1. Go to Certificates, Identifiers & Profiles
# 2. Create APNs Auth Key (or use existing)
# 3. Download .p8 file
# 4. Note the Key ID and Team ID

# Path to APNs .p8 key file (relative to project root)
APNS_KEY_PATH=./certs/apns-key.p8

# APNs Key ID (10-character string)
APNS_KEY_ID=ABC1234XYZ

# Apple Team ID (10-character string from Apple Developer Account)
APNS_TEAM_ID=TEAM123456

# iOS app bundle identifier
APNS_BUNDLE_ID=com.yourapp.fifi

# Use production APNs server (false for sandbox/development)
APNS_PRODUCTION=false

# Optional: Leave APNS_KEY_PATH empty to disable APNs
# Useful for local development without Apple Developer account

# -----------------------------------------------------------------------------
# FILE UPLOAD CONFIGURATION
# -----------------------------------------------------------------------------
# Legacy local filesystem upload directory (relative to project root)
# Current API image uploads use Cloudinary when CLOUDINARY_* is configured
UPLOAD_DIR=./uploads

# Maximum file size in bytes
# 10MB = 10485760 bytes
# 20MB = 20971520 bytes
MAX_FILE_SIZE=10485760

# Allowed image formats (comma-separated MIME types)
# Default: JPEG, PNG, WebP, HEIC
ALLOWED_IMAGE_TYPES=image/jpeg,image/jpg,image/png,image/webp,image/heic

# Cloudinary upload configuration
# Uploaded images are stored under CLOUDINARY_FOLDER/{domain-folder}
# Example pet upload folder: fifi-alert/pets/{id}
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=fifi-alert

# Future: S3 Configuration (not implemented in MVP Phase 1)
# S3_BUCKET=fifi-alert-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# -----------------------------------------------------------------------------
# RATE LIMITING CONFIGURATION
# -----------------------------------------------------------------------------
# Alert creation rate limits per user (enforced via Redis)
# These limits prevent abuse and ensure system stability

# Maximum alerts a user can create per hour
RATE_LIMIT_ALERTS_PER_HOUR=5

# Maximum alerts a user can create per 24 hours
RATE_LIMIT_ALERTS_PER_DAY=20

# Maximum alerts a user can create per 7 days
RATE_LIMIT_ALERTS_PER_WEEK=50

# Global API rate limit (requests per minute)
# Applied to all endpoints via NestJS ThrottlerModule
THROTTLE_TTL=60000  # Time window in milliseconds (60000 = 1 minute)
THROTTLE_LIMIT=60   # Max requests per time window

# -----------------------------------------------------------------------------
# GEOSPATIAL CONFIGURATION
# -----------------------------------------------------------------------------
# Default alert search radius in kilometers
# Used when client doesn't specify radius
DEFAULT_SEARCH_RADIUS_KM=10

# Maximum allowed search radius in kilometers
# Prevents overly broad queries that could impact performance
MAX_SEARCH_RADIUS_KM=100

# GPS freshness thresholds (in hours)
# Fresh GPS: < 2 hours → HIGH confidence notifications
# Stale GPS: 2-24 hours → MEDIUM confidence notifications
# Old GPS: > 24 hours → Not used for GPS matching
GPS_FRESH_THRESHOLD_HOURS=2
GPS_STALE_THRESHOLD_HOURS=24

# Location confidence radius expansion (in kilometers)
# Stale GPS: base radius + this value
# IP geolocation: base radius + this value
STALE_GPS_RADIUS_EXPANSION_KM=5
IP_GEO_RADIUS_EXPANSION_KM=15

# -----------------------------------------------------------------------------
# NOTIFICATION CONFIGURATION
# -----------------------------------------------------------------------------
# Notification job queue configuration
# Max retries for failed push notifications
NOTIFICATION_MAX_RETRIES=3

# Retry backoff (exponential)
# First retry: 1 second
# Second retry: 5 seconds
# Third retry: 30 seconds
NOTIFICATION_RETRY_DELAY_MS=1000

# Job timeout (milliseconds)
# Prevent hanging jobs from blocking queue
NOTIFICATION_JOB_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------------------------
# Email system provider selection
# Options: 'smtp' (default) | 'mailgun'
# Switch providers by changing this value (no code changes required)
MAIL_SYSTEM=smtp

# Email sender defaults
# Used as default 'from' address if not specified in email data
EMAIL_FROM_NAME=FiFi Alert
EMAIL_FROM_EMAIL=noreply@fifi-alert.com

# --- SMTP Configuration (when MAIL_SYSTEM=smtp) ---
# Standard SMTP server configuration
# Works with any SMTP provider (Gmail, Outlook, SendGrid, custom server)

# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP server port
# 587 = TLS (recommended)
# 465 = SSL
# 25 = Unencrypted (not recommended)
SMTP_PORT=587

# Use secure connection (true for port 465, false for port 587)
SMTP_SECURE=false

# SMTP authentication credentials
# Gmail: Use App Password (https://myaccount.google.com/apppasswords)
# Outlook: Use account password
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Default sender name and email
# Overrides EMAIL_FROM_NAME and EMAIL_FROM_EMAIL for SMTP
SMTP_FROM_NAME=FiFi Alert
SMTP_FROM_EMAIL=noreply@fifi-alert.com

# Optional: Preset provider configuration
# Simplifies setup for common providers
# Options: gmail | outlook | yahoo | sendgrid
# If set, SMTP_HOST and SMTP_PORT are ignored in favor of preset
# SMTP_PROVIDER=gmail

# --- Common SMTP Provider Examples ---
# Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASSWORD=your-app-password (not your Gmail password!)
#
# Outlook/Hotmail:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-email@outlook.com
#   SMTP_PASSWORD=your-outlook-password
#
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASSWORD=your-sendgrid-api-key

# --- Mailgun Configuration (when MAIL_SYSTEM=mailgun) ---
# Mailgun API-based email sending
# Requires paid Mailgun account: https://www.mailgun.com/

# Mailgun API key (starts with 'key-...')
# Get from: Mailgun Dashboard > Settings > API Keys
# MAILGUN_API_KEY=key-your-mailgun-api-key

# Mailgun verified sending domain
# Must be verified in Mailgun Dashboard
# Example: mg.fifi-alert.com
# MAILGUN_DOMAIN=mg.yourdomain.com

# Mailgun API base URL
# US region: https://api.mailgun.net
# EU region: https://api.eu.mailgun.net
# MAILGUN_BASE_URL=https://api.mailgun.net

# -----------------------------------------------------------------------------
# ALERT CONFIGURATION
# -----------------------------------------------------------------------------
# Default alert expiration (in days)
# Alerts automatically expire after this period
ALERT_EXPIRATION_DAYS=7

# Maximum alert renewals allowed
# Users can renew alerts this many times before creating a new one
MAX_ALERT_RENEWALS=3

# Maximum photos per alert
MAX_ALERT_PHOTOS=5

# -----------------------------------------------------------------------------
# SAVED ZONE CONFIGURATION
# -----------------------------------------------------------------------------
# Maximum saved zones per device
# Users can define priority areas (home, work, etc.)
MAX_SAVED_ZONES_PER_DEVICE=5

# Saved zone radius constraints (kilometers)
MIN_SAVED_ZONE_RADIUS_KM=1
MAX_SAVED_ZONE_RADIUS_KM=20

# -----------------------------------------------------------------------------
# DATABASE PERFORMANCE
# -----------------------------------------------------------------------------
# Prisma connection pool size
# Adjust based on expected concurrent connections
# Development: 5-10
# Production: 20-50 (depends on load)
DATABASE_POOL_SIZE=10

# Query timeout (milliseconds)
# Prevent long-running queries from blocking
DATABASE_QUERY_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking (optional)
# Get from Sentry.io project settings
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Enable Prisma query logging (development only)
# Set to 'true' to log all SQL queries
PRISMA_LOG_QUERIES=false

# Enable API request logging
# Logs all incoming HTTP requests
ENABLE_REQUEST_LOGGING=true

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Enable/disable features for gradual rollout

# Enable sighting photo uploads
ENABLE_SIGHTING_PHOTOS=true

# Enable alert renewal feature
ENABLE_ALERT_RENEWAL=true

# Enable IP geolocation fallback
# Use IP-based location when GPS unavailable
ENABLE_IP_GEOLOCATION=true

# Enable notification exclusion tracking
# Logs why devices were excluded from notifications
ENABLE_EXCLUSION_TRACKING=true

# -----------------------------------------------------------------------------
# DEVELOPMENT & DEBUGGING
# -----------------------------------------------------------------------------
# Enable Swagger API documentation at /api
# Set to 'false' in production for security
ENABLE_SWAGGER=true

# Enable detailed error responses (stack traces)
# SECURITY: Must be 'false' in production
ENABLE_DETAILED_ERRORS=true

# Seed database with test data on startup
# Only use in development/staging environments
SEED_ON_STARTUP=false
