{
  "name": "comment-classifier-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "bun --watch ./src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "cli": "bun run src/cli.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed:mvp": "bun run scripts/seed-mvp-phase1.ts",
    "verify:postgis": "bun run scripts/verify-postgis.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/platform-socket.io": "^11.1.13",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.13",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@supercharge/request-ip": "^1.2.0",
    "@thallesp/nestjs-better-auth": "^2.2.5",
    "apn": "^2.2.0",
    "axios": "^1.13.4",
    "bullmq": "^5.67.2",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "cacheable": "^2.3.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express-session": "^1.19.0",
    "firebase-admin": "^13.6.1",
    "form-data": "^4.0.5",
    "graphql": "^16.12.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "mailgun.js": "^12.7.0",
    "mjml": "^4.18.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "nest-commander": "^3.20.1",
    "nest-winston": "^1.10.2",
    "nodemailer": "^8.0.1",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "prisma": "^7.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "slug": "^11.0.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.11",
    "@types/bun": "^1.3.8",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.0",
    "@types/nodemailer": "^7.0.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "nest-commander-schematics": "^3.2.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@prisma-lib/(.*)$": "<rootDir>/generated/prisma/$1",
      "^@generated/(.*)$": "<rootDir>/generated/prisma/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@helpers/(.*)$": "<rootDir>/helpers/$1",
      "^@models/(.*)$": "<rootDir>/models/$1",
      "^@services/(.*)$": "<rootDir>/services/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@user/(.*)$": "<rootDir>/user/$1",
      "^@discount/(.*)$": "<rootDir>/discount/$1",
      "^@auth/(.*)$": "<rootDir>/auth/$1",
      "^@brand/(.*)$": "<rootDir>/brand/$1",
      "^@interceptors/(.*)$": "<rootDir>/interceptors/$1",
      "^@cardHolder/(.*)$": "<rootDir>/card-holder/$1",
      "^@firebase/(.*)$": "<rootDir>/firebase/$1",
      "^@decorators/(.*)$": "<rootDir>/decorators/$1",
      "^@exceptions/(.*)$": "<rootDir>/exceptions/$1",
      "^@image/(.*)$": "<rootDir>/image/$1",
      "^@exelsys/(.*)$": "<rootDir>/exelsys/$1",
      "^@metrics/(.*)$": "<rootDir>/metrics/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(slug)/)"
    ]
  }
}